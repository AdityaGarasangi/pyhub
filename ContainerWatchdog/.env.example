# ══════════════════════════════════════════════════════
#  container-watchdog  —  environment configuration
# ══════════════════════════════════════════════════════

# ── REQUIRED ──────────────────────────────────────
TELEGRAM_WATCHDOG_TOKEN=Your_Telegram_Bot_Token
TELEGRAM_CHAT_ID=Your_Chat_ID


# ── Identity ───────────────────────────────────────────
HOSTNAME=Your_Machine_HostName


# ── Container events to watch ──────────────────────────
# Full list of valid actions:
#   attach, commit, copy, create, destroy, detach, die,
#   exec_create, exec_detach, exec_die, exec_start,
#   export, health_status, kill, oom, pause, rename,
#   resize, restart, start, stop, top, unpause, update
WATCH_ACTIONS=start,die,stop,kill,oom,health_status,restart


# ── Network events to watch ────────────────────────────
# Leave blank to disable network alerts entirely.
# Valid: connect, disconnect, create, destroy
WATCH_NETWORK=connect,disconnect


# ── Volume events to watch ─────────────────────────────
# Leave blank to disable volume alerts entirely.
# Valid: create, destroy, mount, unmount
WATCH_VOLUME=


# ── Image events to watch ──────────────────────────────
# Leave blank to disable image alerts entirely.
# Valid: delete, import, load, pull, push, save, tag, untag
WATCH_IMAGE=pull


# ── Container filters ──────────────────────────────────
# Comma-separated name fragments to silence (partial match)
IGNORE_CONTAINERS=

# Only alert on containers whose name contains one of these
# Leave blank = watch everything
WATCH_CONTAINERS=


# ── Rate limiting ──────────────────────────────────────
# Max N alerts per (container + action) per window (seconds)
RATE_LIMIT_MAX=5
RATE_LIMIT_WINDOW=60


# ── Telegram retries ───────────────────────────────────
RETRY_ATTEMPTS=3
RETRY_BACKOFF=2.0                  # seconds, doubles each retry


# ── Startup / shutdown pings ───────────────────────────
NOTIFY_STARTUP=true
NOTIFY_SHUTDOWN=true


# ── Logging ────────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO


# ── Docker socket GID ──────────────────────────────────
# Run: DOCKER_GID=$(stat -c '%g' /var/run/docker.sock)
DOCKER_GID=1001